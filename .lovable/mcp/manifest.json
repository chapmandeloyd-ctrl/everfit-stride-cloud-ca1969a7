            "servings_eaten": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 20,
              "default": 1
            },
            "log_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "YYYY-MM-DD, defaults to today."
            },
            "notes": {
              "type": "string"
            }
          },
