      {
        "name": "create_client_task",
        "title": "Create client task",
        "description": "Assign a task to one of the signed-in trainer's clients. The trainer_id is taken from the OAuth token, never from input.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "client_id": {
              "type": "string",
              "format": "uuid",
              "description": "Target client's profile id."
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Short task name shown to the client."
            },
            "description": {
              "type": "string",
              "description": "Optional longer description."
            },
            "task_type": {
              "type": "string",
              "enum": [
                "general",
                "progress_photo",
                "body_metrics",
                "form",
                "habit"
              ],
              "default": "general",
              "description": "Task category."
            },
            "due_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Optional due date, YYYY-MM-DD."
            }
          },
          "required": [
            "client_id",
            "name"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
